{
  "name": "hevy-mcp",
  "version": "1.0.0",
  "description": "Single-user remote MCP server for the Hevy workout app (OAuth-protected, Streamable HTTP)",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.9.0",
    "jose": "^6.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "@types/bun": "latest",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
