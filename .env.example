# The Hevy API key (api-key header). Get it from the Hevy app: Settings > Developer.
HEVY_API_KEY=00000000-0000-0000-0000-000000000000

# The single-user password you type on the OAuth login page when connecting Claude.
MCP_PASSWORD=change-me-to-a-strong-password

# Random secret (>= 32 bytes) used to sign all JWTs (auth codes + access/refresh tokens).
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Public HTTPS base URL where this server is reachable (no trailing slash).
# Used as the OAuth issuer/audience/resource and in discovery documents.
# Locally you can use http://localhost:3000
PUBLIC_URL=http://localhost:3000

# Port to listen on.
PORT=3000
